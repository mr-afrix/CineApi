# Cine API Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# TMDB API Key (free at themoviedb.org)
TMDB_KEY=1739012afb6a538588d51ce8e9bded3a

# API Keys — add/remove as needed, comma-separated: key:tier:rpm:name
# Tiers: enterprise, pro, free
API_KEYS=cine-2026:enterprise:600:Master,cine-pro-2026:pro:200:Pro,cine-free:free:30:Free

# Cache SQLite path (persists across restarts)
CACHE_DB_PATH=./data/cache.sqlite

# Playwright: number of warm browser instances to keep alive
PLAYWRIGHT_POOL_SIZE=2

# Request timeout ms for got-scraping (default 20s)
SCRAPER_TIMEOUT=20000

# Playwright timeout ms (default 30s)
PLAYWRIGHT_TIMEOUT=30000
